<div class="flex h-full">
  <div class="flex-1 overflow-y-auto">
    <div class="px-6 py-3 border-b border-gray-200 bg-white flex items-center justify-between">
      <h1 class="text-sm font-semibold text-gray-900">Crops</h1>
      <%= link_to "New", new_crop_path,
          data: { turbo_frame: "inspect" },
          class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-gray-900 rounded-md hover:bg-gray-700" %>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nursery</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Planted</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Qty</th>
        </tr>
      </thead>
      <tbody id="crops" class="bg-white divide-y divide-gray-100">
        <% @crops.each do |crop| %>
          <%= render "row", crop: crop %>
        <% end %>
      </tbody>
    </table>
    <% if @crops.empty? %>
      <div class="px-6 py-12 text-center text-gray-400 text-sm">No crops yet. Click "New" to get started.</div>
    <% end %>
  </div>

  <div class="w-80 shrink-0 border-l border-gray-200 bg-white overflow-y-auto">
    <%= turbo_frame_tag "inspect" do %>
      <%= render "form", crop: @crop %>
    <% end %>
  </div>
</div>
