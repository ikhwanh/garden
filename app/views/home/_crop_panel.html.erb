<% if reminders.any? %>
  <div class="space-y-4">
    <% reminders.each do |reminder| %>
      <% d = reminder.details %>
      <div class="border-l-2 border-gray-200 pl-3" data-reminder-due="<%= reminder.due_on %>">
        <div class="flex items-baseline justify-between gap-2 mb-1.5">
          <span class="text-xs font-semibold text-gray-700"><%= reminder.category.humanize %></span>
          <span class="text-xs text-gray-400 flex-shrink-0"><%= reminder.due_on.strftime("%b %-d, %Y") %></span>
        </div>
        <p class="text-xs text-gray-400 mb-1.5"><%= reminder.phase %></p>

        <% case reminder.category %>
        <% when "crop_protection", "pruning_trimming" %>
          <% if d["actions"].present? %>
            <ul class="space-y-0.5">
              <% d["actions"].each do |action| %>
                <li class="text-xs text-gray-600 before:content-['–'] before:mr-1.5 before:text-gray-400"><%= action %></li>
              <% end %>
            </ul>
          <% end %>

        <% when "fertilization_schedule" %>
          <% if d["fertilizers"].present? %>
            <div class="flex flex-wrap gap-1 mb-1">
              <% d["fertilizers"].each do |f| %>
                <span class="inline-block px-1.5 py-0.5 bg-green-50 text-green-700 text-xs rounded"><%= f %></span>
              <% end %>
            </div>
          <% end %>
          <% if d["notes"].present? %>
            <p class="text-xs text-gray-500 italic"><%= d["notes"] %></p>
          <% end %>

        <% when "pest_disease_checklist" %>
          <% if d["pests"].present? %>
            <div class="space-y-1.5">
              <% d["pests"].each do |pest| %>
                <div class="pl-2 border-l-2 border-orange-200">
                  <p class="text-xs font-medium text-gray-700"><%= pest["name"] %></p>
                  <% if pest["inspect_part"].present? %>
                    <p class="text-xs text-gray-500">Inspect: <span class="text-gray-600"><%= pest["inspect_part"] %></span></p>
                  <% end %>
                  <% if pest["action_threshold"].present? %>
                    <p class="text-xs text-gray-500">Threshold: <span class="text-gray-600"><%= pest["action_threshold"] %></span></p>
                  <% end %>
                  <% if pest["inspection_interval_days"].present? %>
                    <p class="text-xs text-gray-500">Every <%= pest["inspection_interval_days"] %> days</p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>

        <% when "growth_benchmarks" %>
          <% if (t = d["targets"]).present? %>
            <div class="flex flex-wrap gap-x-4 gap-y-1 mb-1">
              <% if t["plant_height_cm"] %>
                <span class="text-xs text-gray-600">Height <strong><%= t["plant_height_cm"]["min"] %>–<%= t["plant_height_cm"]["max"] %> cm</strong></span>
              <% end %>
              <% if t["leaf_count"] %>
                <span class="text-xs text-gray-600">Leaves <strong><%= t["leaf_count"]["min"] %>–<%= t["leaf_count"]["max"] %></strong></span>
              <% end %>
              <% if t["stem_diameter_cm"] %>
                <span class="text-xs text-gray-600">Stem <strong><%= t["stem_diameter_cm"]["min"] %>–<%= t["stem_diameter_cm"]["max"] %> cm</strong></span>
              <% end %>
            </div>
          <% end %>
          <% if d["notes"].present? %>
            <p class="text-xs text-gray-500 italic"><%= d["notes"] %></p>
          <% end %>

        <% when "soil_parameters" %>
          <% if (t = d["targets"]).present? %>
            <div class="flex flex-wrap gap-x-4 gap-y-1">
              <% if t["pH"] %>
                <span class="text-xs text-gray-600">pH <strong><%= t["pH"]["min"] %>–<%= t["pH"]["max"] %></strong></span>
              <% end %>
              <% if t["moisture_pct"] %>
                <span class="text-xs text-gray-600">Moisture <strong><%= t["moisture_pct"]["min"] %>–<%= t["moisture_pct"]["max"] %>%</strong></span>
              <% end %>
              <% if t["ec_ms_cm"] %>
                <span class="text-xs text-gray-600">EC <strong><%= t["ec_ms_cm"]["min"] %>–<%= t["ec_ms_cm"]["max"] %> mS/cm</strong></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-xs text-gray-400">No treatments scheduled.</p>
<% end %>
