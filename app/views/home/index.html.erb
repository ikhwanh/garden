<% content_for :title, "Dashboard – Garden" %>

<% if user_signed_in? %>
  <div class="p-6 overflow-y-auto h-full">
    <h1 class="text-lg font-semibold text-gray-900 mb-6">Dashboard</h1>

<%# Success Rate widget %>
    <% if @nursery_rates.any? || @crop_rates.any? %>
      <div class="bg-white border border-gray-200 rounded-lg p-4 mb-6">
        <h2 class="text-sm font-medium text-gray-900 mb-3">Success Rate</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-2">Nursery</p>
            <% if @nursery_rates.any? %>
              <ul class="space-y-2">
                <% @nursery_rates.each do |nursery| %>
                  <% rate = nursery.success_rate %>
                  <li>
                    <div class="flex items-center justify-between text-xs mb-1">
                      <span class="text-gray-700 truncate"><%= nursery.name %></span>
                      <span class="text-gray-500 ml-2 flex-shrink-0"><%= rate %>%</span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-1.5">
                      <div class="h-1.5 rounded-full <%= rate >= 75 ? 'bg-green-500' : rate >= 50 ? 'bg-yellow-400' : 'bg-red-400' %>"
                           style="width: <%= [ rate, 100 ].min %>%"></div>
                    </div>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-xs text-gray-400">No data yet.</p>
            <% end %>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-2">Harvest</p>
            <% if @crop_rates.any? %>
              <ul class="space-y-2">
                <% @crop_rates.each do |crop| %>
                  <% rate = crop.success_rate %>
                  <li>
                    <div class="flex items-center justify-between text-xs mb-1">
                      <span class="text-gray-700 truncate"><%= crop.name %></span>
                      <span class="text-gray-500 ml-2 flex-shrink-0"><%= rate %>%</span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-1.5">
                      <div class="h-1.5 rounded-full <%= rate >= 75 ? 'bg-green-500' : rate >= 50 ? 'bg-yellow-400' : 'bg-red-400' %>"
                           style="width: <%= [ rate, 100 ].min %>%"></div>
                    </div>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-xs text-gray-400">No data yet.</p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Cashflow widget %>
    <div class="mb-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-medium text-gray-900">Cashflow</h2>
        <%= form_with url: root_path, method: :get, data: { turbo: false }, class: "flex items-center gap-2" do |f| %>
          <%= f.date_field :cf_start, value: @cf_start_date,
              class: "border border-gray-300 rounded-md px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-gray-400" %>
          <span class="text-xs text-gray-400">to</span>
          <%= f.date_field :cf_end, value: @cf_end_date,
              class: "border border-gray-300 rounded-md px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-gray-400" %>
          <%= f.select :cf_cost_type,
              [["All types", ""], ["Fixed", "fixed"], ["Variable", "variable"]],
              { selected: @cf_cost_type.to_s },
              class: "border border-gray-300 rounded-md px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-gray-400" %>
          <%= f.submit "Filter", class: "px-2.5 py-1 text-xs font-medium border border-gray-300 rounded-md text-gray-600 hover:bg-gray-50 cursor-pointer" %>
        <% end %>
      </div>

      <%# Summary numbers %>
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div class="bg-white border border-gray-200 rounded-lg p-3">
          <p class="text-xs text-gray-500 mb-1">Total Income</p>
          <p class="text-base font-semibold text-green-700"><%= currency_rp(@cf_total_income) %></p>
        </div>
        <div class="bg-white border border-gray-200 rounded-lg p-3">
          <p class="text-xs text-gray-500 mb-1">Total Expenses</p>
          <p class="text-base font-semibold text-red-700"><%= currency_rp(@cf_total_expenses) %></p>
        </div>
        <div class="bg-white border border-gray-200 rounded-lg p-3">
          <p class="text-xs text-gray-500 mb-1">Net</p>
          <p class="text-base font-semibold <%= @cf_net >= 0 ? 'text-green-700' : 'text-red-700' %>">
            <%= @cf_net >= 0 ? "+ " : "- " %><%= currency_rp(@cf_net.abs) %>
          </p>
        </div>
      </div>

      <%# Break-even chart %>
      <div class="bg-white border border-gray-200 rounded-lg p-4">
        <% if @cf_chart_labels.any? %>
          <div class="h-56">
            <canvas
              data-controller="cashflow-chart"
              data-cashflow-chart-labels-value="<%= @cf_chart_labels.to_json %>"
              data-cashflow-chart-income-value="<%= @cf_chart_income.to_json %>"
              data-cashflow-chart-expenses-value="<%= @cf_chart_expenses.to_json %>"
            ></canvas>
          </div>
        <% else %>
          <p class="text-xs text-gray-400 text-center py-8">No cashflow entries yet. <%= link_to "Add your first entry", cashflow_path, class: "underline hover:text-gray-600" %>.</p>
        <% end %>
      </div>
    </div>

    <%# Calendar export widget %>
    <% calendar = GardenCalendar.new(current_user) %>
    <div class="bg-white border border-gray-200 rounded-lg p-4 max-w-sm mb-4">
      <h2 class="text-sm font-medium text-gray-900 mb-1">Calendar export</h2>
      <p class="text-xs text-gray-500 mb-3">Download your schedule — germination and harvest dates — as an .ics file to import into Google Calendar or any calendar app.</p>
      <% if calendar.any_events? %>
        <%= link_to calendar_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download .ics
        <% end %>
      <% else %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 text-gray-400 text-sm font-medium rounded-md cursor-not-allowed">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download .ics
        </span>
        <p class="mt-2 text-xs text-gray-400">No calendar events available.</p>
      <% end %>
    </div>

    <%# Database import / export widget %>
    <div class="bg-white border border-gray-200 rounded-lg p-4 max-w-sm">
      <h2 class="text-sm font-medium text-gray-900 mb-1">Database backup</h2>
      <p class="text-xs text-gray-500 mb-3">Export all your data as a JSON file, or import a previously exported file to restore records.</p>
      <div class="flex items-center gap-2 mb-3">
        <%= link_to database_export_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Export JSON
        <% end %>
      </div>
      <%= form_with url: database_import_path, method: :post, multipart: true, data: { turbo: false } do |f| %>
        <div class="flex items-center gap-2">
          <%= f.file_field :file, accept: ".json,application/json",
              class: "block text-xs text-gray-500 file:mr-2 file:py-1 file:px-2.5 file:rounded file:border file:border-gray-300 file:text-xs file:font-medium file:text-gray-600 file:bg-white hover:file:bg-gray-50 file:cursor-pointer" %>
          <%= f.submit "Import", class: "px-3 py-1.5 text-xs font-medium border border-gray-300 rounded-md text-gray-600 hover:bg-gray-50 cursor-pointer whitespace-nowrap" %>
        </div>
        <p class="mt-2 text-xs text-gray-400">Importing adds records — it does not overwrite existing data.</p>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <h1 class="text-5xl font-bold text-gray-900 mb-4">Welcome to Garden</h1>
      <p class="text-lg text-gray-500 mb-8">A place to grow your ideas.</p>
      <div class="flex gap-3 justify-center">
        <%= link_to "Sign in", new_user_session_path,
              class: "inline-flex items-center px-5 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors" %>
        <%= link_to "Sign up", new_user_registration_path,
              class: "inline-flex items-center px-5 py-2.5 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors" %>
      </div>
    </div>
  </div>
<% end %>
