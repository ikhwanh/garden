<% content_for :title, "Dashboard – Garden" %>

<% if user_signed_in? %>
  <div class="p-6">
    <h1 class="text-lg font-semibold text-gray-900 mb-6">Dashboard</h1>

    <% calendar = GardenCalendar.new(current_user) %>
    <div class="bg-white border border-gray-200 rounded-lg p-4 max-w-sm">
      <h2 class="text-sm font-medium text-gray-900 mb-1">Calendar export</h2>
      <p class="text-xs text-gray-500 mb-3">Download your schedule — germination and harvest dates — as an .ics file to import into Google Calendar or any calendar app.</p>
      <% if calendar.any_events? %>
        <%= link_to calendar_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download .ics
        <% end %>
      <% else %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 text-gray-400 text-sm font-medium rounded-md cursor-not-allowed">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download .ics
        </span>
        <p class="mt-2 text-xs text-gray-400">Add plants with days to maturity or seeds with germination dates first.</p>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <h1 class="text-5xl font-bold text-gray-900 mb-4">Welcome to Garden</h1>
      <p class="text-lg text-gray-500 mb-8">A place to grow your ideas.</p>
      <div class="flex gap-3 justify-center">
        <%= link_to "Sign in", new_user_session_path,
              class: "inline-flex items-center px-5 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors" %>
        <%= link_to "Sign up", new_user_registration_path,
              class: "inline-flex items-center px-5 py-2.5 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors" %>
      </div>
    </div>
  </div>
<% end %>
