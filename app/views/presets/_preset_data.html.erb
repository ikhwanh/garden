<% data = preset.preset_data %>
<% return if data.blank? %>

<%
  section_labels = {
    "crop_protection"        => "Crop Protection",
    "pruning_trimming"       => "Pruning & Trimming",
    "fertilization_schedule" => "Fertilization Schedule",
    "pest_disease_checklist" => "Pest & Disease Checklist",
    "soil_parameters"        => "Soil Parameters",
    "growth_benchmarks"      => "Growth Benchmarks"
  }
  section_order = section_labels.keys
%>

<% (section_order & data.keys).each do |key| %>
  <% phases = data[key] %>
  <% next if phases.blank? %>

  <div class="pt-3 border-t border-gray-100">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= section_labels[key] %></p>

    <div class="space-y-3">
      <% phases.each do |phase| %>
        <% ph = PresetPhase::Base.for(key, phase) %>
        <% details = ph.to_details %>
        <div>
          <div class="flex items-baseline gap-2 mb-1">
            <% if ph.phase_name.present? %>
              <span class="text-xs font-medium text-gray-700"><%= ph.phase_name.humanize %></span>
            <% end %>
            <% if ph.dap_max > 0 && key != "growth_benchmarks" %>
              <span class="text-xs text-gray-400">DAP <%= ph.dap_min %>–<%= ph.dap_max %></span>
            <% end %>
          </div>

          <% case key %>
          <% when "crop_protection", "pruning_trimming" %>
            <% if details[:actions].present? %>
              <ul class="space-y-0.5 pl-3">
                <% details[:actions].each do |action| %>
                  <li class="text-xs text-gray-600 before:content-['–'] before:mr-1.5 before:text-gray-400"><%= action %></li>
                <% end %>
              </ul>
            <% end %>

          <% when "fertilization_schedule" %>
            <% if details[:fertilizers].present? %>
              <div class="flex flex-wrap gap-1 mb-1">
                <% details[:fertilizers].each do |f| %>
                  <span class="inline-block px-1.5 py-0.5 bg-green-50 text-green-700 text-xs rounded"><%= f %></span>
                <% end %>
              </div>
            <% end %>
            <% if ph.interval_days.present? %>
              <p class="text-xs text-gray-500">Every <%= ph.interval_days %> days</p>
            <% end %>
            <% if details[:notes].present? %>
              <p class="text-xs text-gray-500 italic"><%= details[:notes] %></p>
            <% end %>

          <% when "pest_disease_checklist" %>
            <% if details[:pests].present? %>
              <div class="space-y-1.5">
                <% details[:pests].each do |pest| %>
                  <div class="pl-3 border-l-2 border-orange-200">
                    <p class="text-xs font-medium text-gray-700"><%= pest["name"] %></p>
                    <p class="text-xs text-gray-500">Inspect: <span class="text-gray-600"><%= pest["inspect_part"] %></span></p>
                    <p class="text-xs text-gray-500">Threshold: <span class="text-gray-600"><%= pest["action_threshold"] %></span></p>
                    <% if pest["inspection_interval_days"].present? %>
                      <p class="text-xs text-gray-500">Every <%= pest["inspection_interval_days"] %> days</p>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>

          <% when "soil_parameters" %>
            <% t = details[:targets] %>
            <% if t.present? %>
              <div class="flex flex-wrap gap-x-4 gap-y-1">
                <% if t["pH"] %>
                  <span class="text-xs text-gray-600">pH <strong><%= t["pH"]["min"] %>–<%= t["pH"]["max"] %></strong></span>
                <% end %>
                <% if t["moisture_pct"] %>
                  <span class="text-xs text-gray-600">Moisture <strong><%= t["moisture_pct"]["min"] %>–<%= t["moisture_pct"]["max"] %>%</strong></span>
                <% end %>
                <% if t["ec_ms_cm"] %>
                  <span class="text-xs text-gray-600">EC <strong><%= t["ec_ms_cm"]["min"] %>–<%= t["ec_ms_cm"]["max"] %> mS/cm</strong></span>
                <% end %>
              </div>
            <% end %>
            <% if details[:notes].present? %>
              <p class="text-xs text-gray-500 italic mt-1"><%= details[:notes] %></p>
            <% end %>

          <% when "growth_benchmarks" %>
            <% t = details[:targets] %>
            <% if t.present? %>
              <div class="flex flex-wrap gap-x-4 gap-y-1">
                <% t.each do |metric, range| %>
                  <% label = metric.gsub("_", " ").gsub(/\b(\w)/) { $1.upcase } %>
                  <span class="text-xs text-gray-600"><%= label %> <strong><%= range["min"] %>–<%= range["max"] %></strong></span>
                <% end %>
              </div>
            <% end %>
            <% if details[:notes].present? %>
              <p class="text-xs text-gray-500 italic mt-1"><%= details[:notes] %></p>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
