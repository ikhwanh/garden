<div class="p-4">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-gray-900"><%= preset.new_record? ? "New Preset" : "Edit Preset" %></h2>
    <%= link_to "Cancel",
        preset.new_record? ? presets_path : preset_path(preset),
        data: { turbo_frame: "inspect" },
        class: "text-xs text-gray-500 hover:text-gray-700" %>
  </div>

  <%= form_with model: preset, data: { controller: "preset-form" } do |f| %>
    <% if preset.errors.any? %>
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md">
        <ul class="text-xs text-red-700 space-y-0.5">
          <% preset.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
        <%= f.text_field :name,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Slug <span class="text-red-500">*</span></label>
        <%= f.text_field :slug,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Local Name</label>
        <%= f.text_field :local_name,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Grow Type <span class="text-red-500">*</span></label>
        <%= f.select :grow_type,
            Preset::GROW_TYPES.map { |t| [t.capitalize, t] },
            { include_blank: "Select…" },
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400",
            data: { action: "change->preset-form#toggle" } %>
      </div>
      <div data-preset-form-target="harvestFields" class="grid grid-cols-2 gap-2">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Min Days to Harvest</label>
          <%= f.number_field :days_min, min: 1,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Max Days to Harvest</label>
          <%= f.number_field :days_max, min: 1,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
        </div>
      </div>
    </div>

    <div class="mt-5">
      <%= f.submit preset.new_record? ? "Create" : "Update",
          class: "w-full px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
