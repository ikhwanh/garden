<div class="p-4 space-y-4">
  <div class="flex items-start justify-between gap-2">
    <h2 class="text-base font-semibold text-gray-900"><%= preset.name %></h2>
    <div class="flex items-center gap-3 shrink-0">
      <%= link_to "Edit", edit_preset_path(preset),
          data: { turbo_frame: "inspect" },
          class: "text-xs text-gray-500 hover:text-gray-900" %>
      <%= button_to "Delete", preset_path(preset), method: :delete,
          data: { turbo_confirm: "Delete \"#{preset.name}\"?" },
          class: "text-xs text-red-500 hover:text-red-700 bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>

  <dl class="space-y-3">
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Slug</dt>
      <dd class="mt-0.5 text-sm text-gray-900 font-mono"><%= preset.slug %></dd>
    </div>
    <% if preset.local_name.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Local Name</dt>
        <dd class="mt-0.5 text-sm text-gray-900"><%= preset.local_name %></dd>
      </div>
    <% end %>
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Grow Type</dt>
      <dd class="mt-0.5 text-sm text-gray-900"><%= preset.grow_type.capitalize %></dd>
    </div>
    <% if preset.days_to_harvest_min.present? || preset.days_to_harvest_max.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Days to Harvest</dt>
        <dd class="mt-0.5 text-sm text-gray-900">
          <%= [preset.days_to_harvest_min, preset.days_to_harvest_max].compact.join(" – ") %> days
        </dd>
      </div>
    <% end %>
  </dl>

  <%= render "preset_data", preset: preset %>

  <% if preset.crops.any? %>
    <div class="pt-3 border-t border-gray-100">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-2">Crops using this preset</p>
      <ul class="space-y-1">
        <% preset.crops.each do |crop| %>
          <li>
            <%= link_to crop.name, crop_path(crop),
                data: { turbo_frame: "inspect" },
                class: "text-sm text-blue-600 hover:text-blue-800" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
