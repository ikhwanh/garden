<div class="flex h-full">
  <div class="flex-1 overflow-y-auto">
    <div class="px-6 py-3 border-b border-gray-200 bg-white flex items-center justify-between">
      <h1 class="text-sm font-semibold text-gray-900">Presets</h1>
      <%= link_to "New", new_preset_path,
          data: { turbo_frame: "inspect" },
          class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-gray-900 rounded-md hover:bg-gray-700" %>
    </div>
    <% sort_url = ->(s, d) { presets_path(sort: s, direction: d) } %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <%= render "shared/sort_th", label: "Name", column: "name", sort_column: @sort_column, sort_direction: @sort_direction, url: sort_url %>
          <%= render "shared/sort_th", label: "Local Name", column: "local_name", sort_column: @sort_column, sort_direction: @sort_direction, url: sort_url %>
          <%= render "shared/sort_th", label: "Grow Type", column: "grow_type", sort_column: @sort_column, sort_direction: @sort_direction, url: sort_url %>
          <%= render "shared/sort_th", label: "Days to Harvest", column: "days_to_harvest_min", sort_column: @sort_column, sort_direction: @sort_direction, url: sort_url %>
        </tr>
      </thead>
      <tbody id="presets" class="bg-white divide-y divide-gray-100">
        <% @presets.each do |preset| %>
          <%= render "row", preset: preset %>
        <% end %>
      </tbody>
    </table>
    <%= render "shared/pagination",
        current_page: @current_page,
        total_pages: @total_pages,
        url_for_page: ->(page) { presets_path(page: page, sort: @sort_column, direction: @sort_direction) } %>
    <% if @presets.empty? %>
      <div class="px-6 py-12 text-center text-gray-400 text-sm">No presets yet. Click "New" to get started.</div>
    <% end %>
  </div>

  <div class="w-80 shrink-0 border-l border-gray-200 bg-white overflow-y-auto">
    <%= turbo_frame_tag "inspect" do %>
      <%= render "form", preset: @preset %>
    <% end %>
  </div>
</div>
