<div class="p-4 space-y-4">
  <div class="flex items-start justify-between gap-2">
    <div>
      <h2 class="text-base font-semibold text-gray-900"><%= fertilization.fertilizer_type %></h2>
      <p class="text-xs text-gray-500 mt-0.5">
        <%= link_to fertilization.plant.name, plant_path(fertilization.plant),
            data: { turbo_frame: "inspect" },
            class: "hover:text-gray-900" %>
      </p>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <%= link_to "Edit", edit_fertilization_path(fertilization),
          data: { turbo_frame: "inspect" },
          class: "text-xs text-gray-500 hover:text-gray-900" %>
      <%= button_to "Delete", fertilization_path(fertilization), method: :delete,
          data: { turbo_confirm: "Delete this fertilization?" },
          class: "text-xs text-red-500 hover:text-red-700 bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>

  <dl class="space-y-3">
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Applied On</dt>
      <dd class="mt-0.5 text-sm text-gray-900"><%= fertilization.applied_on.strftime("%B %d, %Y") %></dd>
    </div>
    <% if fertilization.amount.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Amount</dt>
        <dd class="mt-0.5 text-sm text-gray-900"><%= fertilization.amount %> <%= fertilization.unit %></dd>
      </div>
    <% end %>
  </dl>
</div>
