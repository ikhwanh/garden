<tr id="fertilization_<%= fertilization.id %>" class="hover:bg-gray-50">
  <td class="px-4 py-2.5 text-sm font-medium text-gray-900">
    <%= link_to fertilization.fertilizer_type, fertilization_path(fertilization),
        data: { turbo_frame: "inspect" },
        class: "hover:text-blue-600" %>
  </td>
  <td class="px-4 py-2.5 text-sm text-gray-500">
    <%= link_to fertilization.plant.name, plant_path(fertilization.plant),
        data: { turbo_frame: "inspect" },
        class: "hover:text-blue-600" %>
  </td>
  <td class="px-4 py-2.5 text-sm text-gray-500"><%= fertilization.applied_on.strftime("%b %d, %Y") %></td>
  <td class="px-4 py-2.5 text-sm text-gray-500">
    <%= fertilization.amount.present? ? "#{fertilization.amount} #{fertilization.unit}" : "—" %>
  </td>
</tr>
