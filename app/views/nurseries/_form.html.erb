<div class="p-4">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-gray-900"><%= nursery.new_record? ? "New Nursery" : "Edit Nursery" %></h2>
    <%= link_to "Cancel",
        nursery.new_record? ? nurseries_path : nursery_path(nursery),
        data: { turbo_frame: "inspect" },
        class: "text-xs text-gray-500 hover:text-gray-700" %>
  </div>

  <%= form_with model: nursery do |f| %>
    <% if nursery.errors.any? %>
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md">
        <ul class="text-xs text-red-700 space-y-0.5">
          <% nursery.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
        <%= f.text_field :name,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Started</label>
        <%= f.date_field :started_on,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Qty Sown</label>
        <%= f.number_field :quantity_initial, min: 1,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Note</label>
        <%= f.text_area :note, rows: 3,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400 resize-none" %>
      </div>
    </div>

    <div class="mt-5">
      <%= f.submit nursery.new_record? ? "Create" : "Update",
          class: "w-full px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
