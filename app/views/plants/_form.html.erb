<div class="p-4">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-gray-900"><%= plant.new_record? ? "New Plant" : "Edit Plant" %></h2>
    <%= link_to "Cancel",
        plant.new_record? ? plants_path : plant_path(plant),
        data: { turbo_frame: "inspect" },
        class: "text-xs text-gray-500 hover:text-gray-700" %>
  </div>

  <%= form_with model: plant do |f| %>
    <% if plant.errors.any? %>
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md">
        <ul class="text-xs text-red-700 space-y-0.5">
          <% plant.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
        <%= f.text_field :name,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Seed</label>
        <%= f.select :seed_id,
            @seeds.map { |s| [ s.name, s.id ] },
            { include_blank: "Select a seed…" },
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Grow Medium <span class="text-red-500">*</span></label>
        <%= f.select :grow_medium,
            Plant::GROW_MEDIUMS.map { |m| [ m.capitalize, m ] },
            { include_blank: "Select…" },
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Planted On <span class="text-red-500">*</span></label>
        <%= f.date_field :planted_on,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Days to Maturity</label>
        <%= f.number_field :days_to_maturity, placeholder: "e.g. 75",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Container Size</label>
        <%= f.text_field :container_size, placeholder: "e.g. 5L pot",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Location</label>
        <%= f.text_field :location, placeholder: "e.g. Greenhouse A",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Qty Initial</label>
          <%= f.number_field :quantity_initial, min: 1,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Qty Final</label>
          <%= f.number_field :quantity_final, min: 0,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Note</label>
        <%= f.text_area :note, rows: 3,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400 resize-none" %>
      </div>
    </div>

    <div class="mt-5">
      <%= f.submit plant.new_record? ? "Create" : "Update",
          class: "w-full px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
