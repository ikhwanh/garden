<div class="flex h-full">
  <div class="flex-1 overflow-y-auto">
    <div class="px-6 py-3 border-b border-gray-200 bg-white flex items-center justify-between">
      <h1 class="text-sm font-semibold text-gray-900">Plants</h1>
      <%= link_to "New Plant", new_plant_path,
          data: { turbo_frame: "inspect" },
          class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-gray-900 rounded-md hover:bg-gray-700" %>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Seed</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Medium</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Planted</th>
        </tr>
      </thead>
      <tbody id="plants" class="bg-white divide-y divide-gray-100">
        <% @plants.each do |plant| %>
          <%= render "row", plant: plant %>
        <% end %>
      </tbody>
    </table>
    <% if @plants.empty? %>
      <div class="px-6 py-12 text-center text-gray-400 text-sm">No plants yet. Click "New Plant" to get started.</div>
    <% end %>
  </div>

  <div class="w-80 shrink-0 border-l border-gray-200 bg-white overflow-y-auto">
    <%= turbo_frame_tag "inspect" do %>
      <div class="p-6 text-center text-gray-400 text-sm mt-16">Select a plant to view details</div>
    <% end %>
  </div>
</div>
