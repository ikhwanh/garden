<div class="p-4 space-y-4">
  <div class="flex items-start justify-between gap-2">
    <div>
      <h2 class="text-base font-semibold text-gray-900"><%= plant.name %></h2>
      <% if plant.seed %>
        <p class="text-xs text-gray-500 mt-0.5"><%= plant.seed.name %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <%= link_to "Edit", edit_plant_path(plant),
          data: { turbo_frame: "inspect" },
          class: "text-xs text-gray-500 hover:text-gray-900" %>
      <%= button_to "Delete", plant_path(plant), method: :delete,
          data: { turbo_confirm: "Delete \"#{plant.name}\"? This will also delete all its reminders." },
          class: "text-xs text-red-500 hover:text-red-700 bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>

  <dl class="grid grid-cols-2 gap-x-4 gap-y-3">
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Medium</dt>
      <dd class="mt-0.5 text-sm text-gray-900 capitalize"><%= plant.grow_medium %></dd>
    </div>
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Planted</dt>
      <dd class="mt-0.5 text-sm text-gray-900"><%= plant.planted_on.strftime("%b %d, %Y") %></dd>
    </div>
    <% if plant.days_to_maturity.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Days to Maturity</dt>
        <dd class="mt-0.5 text-sm text-gray-900"><%= plant.days_to_maturity %> days</dd>
      </div>
    <% end %>
    <% if plant.container_size.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Container</dt>
        <dd class="mt-0.5 text-sm text-gray-900"><%= plant.container_size %></dd>
      </div>
    <% end %>
    <% if plant.location.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Location</dt>
        <dd class="mt-0.5 text-sm text-gray-900"><%= plant.location %></dd>
      </div>
    <% end %>
    <% if plant.quantity_initial.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Quantity</dt>
        <dd class="mt-0.5 text-sm text-gray-900">
          <%= plant.quantity_initial %>
          <% if plant.quantity_final.present? %>
            → <%= plant.quantity_final %>
            <span class="text-gray-500">(<%= plant.success_rate %>%)</span>
          <% end %>
        </dd>
      </div>
    <% end %>
  </dl>

  <% if plant.note.present? %>
    <div class="pt-3 border-t border-gray-100">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Note</p>
      <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= plant.note %></p>
    </div>
  <% end %>

</div>
