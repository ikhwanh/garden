<% if preset %>
  <dl class="space-y-3 mb-4">
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Name</dt>
      <dd class="mt-0.5 text-xs text-gray-700"><%= preset.name %></dd>
    </div>
    <% if preset.local_name.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Local Name</dt>
        <dd class="mt-0.5 text-xs text-gray-700"><%= preset.local_name %></dd>
      </div>
    <% end %>
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Grow Type</dt>
      <dd class="mt-0.5 text-xs text-gray-700"><%= preset.grow_type.capitalize %></dd>
    </div>
    <% if preset.days_to_harvest_min.present? || preset.days_to_harvest_max.present? %>
      <div>
        <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Days to Harvest</dt>
        <dd class="mt-0.5 text-xs text-gray-700">
          <%= [ preset.days_to_harvest_min, preset.days_to_harvest_max ].compact.join(" – ") %> days
        </dd>
      </div>
    <% end %>
  </dl>
  <%= render "presets/preset_data", preset: preset %>
<% else %>
  <p class="text-xs text-gray-400">No preset assigned.</p>
<% end %>
