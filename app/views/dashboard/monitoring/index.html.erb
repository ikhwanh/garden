<% content_for :title, "Monitoring – Garden" %>

<% sort_url = ->(s, d) { dashboard_monitoring_path(sort: s, direction: d) } %>
<div class="flex h-full"
     data-controller="crop-panel"
     data-crop-panel-detail-panel-url-value="<%= dashboard_detail_panel_path %>">

  <%# Card list %>
  <div class="w-64 shrink-0 border-r border-gray-200 flex flex-col">

    <%# Sort bar %>
    <div class="px-3 py-2 border-b border-gray-200 bg-gray-50 flex items-center gap-1 flex-wrap">
      <% [["status", "Status"], ["name", "Name"], ["type", "Type"], ["location", "Location"]].each do |col, label| %>
        <% active = @sort_column == col %>
        <% next_dir = active && @sort_direction == "asc" ? "desc" : "asc" %>
        <%= link_to sort_url.call(col, next_dir),
            class: "px-2 py-0.5 text-[10px] rounded transition-colors #{active ? 'bg-gray-200 text-gray-800 font-semibold' : 'text-gray-400 hover:bg-gray-100 hover:text-gray-600'}" do %>
          <%= label %><%= active ? (@sort_direction == "desc" ? " ↓" : " ↑") : "" %>
        <% end %>
      <% end %>
    </div>

    <%# Cards %>
    <div class="flex-1 overflow-y-auto">
      <% if @monitoring_rows.any? %>
        <div class="divide-y divide-gray-100">
          <% @monitoring_rows.each do |row| %>
            <% obj = row[:object] %>
            <% is_nursery = row[:type] == "nursery" %>
            <div class="px-4 py-3 cursor-pointer hover:bg-gray-50 border-l-2 border-transparent transition-all select-none"
                 data-crop-panel-target="card"
                 data-action="click->crop-panel#showDetail"
                 <%= is_nursery ? "data-crop-panel-nursery-id-param=#{obj.id}" : "data-crop-panel-crop-id-param=#{obj.id}" %>>
              <div class="flex items-center gap-1.5 mb-0.5">
                <% if is_nursery %>
                  <span class="inline-block text-[9px] font-medium px-1 py-0.5 rounded bg-purple-100 text-purple-600">Nursery</span>
                <% else %>
                  <span class="inline-block text-[9px] font-medium px-1 py-0.5 rounded bg-green-100 text-green-700">Crop</span>
                <% end %>
                <% if row[:location] && row[:location] != "Unassigned" %>
                  <span class="text-[9px] text-gray-400 truncate"><%= row[:location] %></span>
                <% end %>
              </div>
              <p class="text-sm font-medium text-gray-900 truncate leading-snug"><%= row[:name] %></p>
              <p class="text-[11px] mt-0.5 <%= row[:status_class] %>"><%= row[:status_text] %></p>
            </div>
          <% end %>
        </div>

        <% if @total_pages > 1 %>
          <div class="px-4 py-2 border-t border-gray-200 flex items-center justify-between text-[10px] text-gray-400">
            <span>Page <%= @current_page %> / <%= @total_pages %></span>
            <div class="flex gap-1.5">
              <% if @current_page > 1 %>
                <%= link_to "←", dashboard_monitoring_path(page: @current_page - 1, sort: @sort_column, direction: @sort_direction),
                    class: "px-1.5 py-0.5 border border-gray-200 rounded hover:bg-gray-50" %>
              <% else %>
                <span class="px-1.5 py-0.5 border border-gray-100 rounded text-gray-200">←</span>
              <% end %>
              <% if @current_page < @total_pages %>
                <%= link_to "→", dashboard_monitoring_path(page: @current_page + 1, sort: @sort_column, direction: @sort_direction),
                    class: "px-1.5 py-0.5 border border-gray-200 rounded hover:bg-gray-50" %>
              <% else %>
                <span class="px-1.5 py-0.5 border border-gray-100 rounded text-gray-200">→</span>
              <% end %>
            </div>
          </div>
        <% end %>

      <% else %>
        <p class="text-xs text-gray-400 px-4 py-12 text-center">No active crops or nurseries.</p>
      <% end %>
    </div>
  </div>

  <%# Detail pane %>
  <div class="flex-1 overflow-y-auto bg-white">
    <div class="flex items-center justify-center h-full" data-crop-panel-target="emptyState">
      <p class="text-sm text-gray-300">Select a crop or nursery</p>
    </div>
    <div class="hidden" data-crop-panel-target="content"></div>
  </div>

</div>
