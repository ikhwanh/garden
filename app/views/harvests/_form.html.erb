<div class="p-4">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-gray-900">
      <%= harvest.new_record? ? "New Harvest" : "Edit Harvest" %>
    </h2>
    <%= link_to "Cancel",
        harvest.new_record? ? plant_path(plant) : harvest_path(harvest),
        data: { turbo_frame: "inspect" },
        class: "text-xs text-gray-500 hover:text-gray-700" %>
  </div>

  <% model = harvest.new_record? ? [ plant, harvest ] : harvest %>
  <%= form_with model: model do |f| %>
    <% if harvest.errors.any? %>
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md">
        <ul class="text-xs text-red-700 space-y-0.5">
          <% harvest.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Harvested On <span class="text-red-500">*</span></label>
        <%= f.date_field :harvested_on,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Weight (g)</label>
        <%= f.number_field :weight_grams, min: 0, step: "0.01",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
      </div>
      <div class="grid grid-cols-2 gap-2">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Quantity</label>
          <%= f.number_field :quantity, min: 1, step: 1,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Unit</label>
          <%= f.text_field :unit, placeholder: "pcs, bunch…",
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
        </div>
      </div>
      <p class="text-xs text-gray-400">Provide weight, quantity, or both.</p>
    </div>

    <div class="mt-5">
      <%= f.submit harvest.new_record? ? "Add Harvest" : "Update Harvest",
          class: "w-full px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
