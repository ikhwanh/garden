<div class="flex h-full">
  <div class="flex-1 overflow-y-auto">
    <div class="px-6 py-3 border-b border-gray-200 bg-white">
      <h1 class="text-sm font-semibold text-gray-900">Harvests</h1>
      <p class="text-xs text-gray-400 mt-0.5">Add harvests from a plant's detail panel.</p>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plant</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Weight</th>
          <th class="px-4 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Qty</th>
        </tr>
      </thead>
      <tbody id="harvests" class="bg-white divide-y divide-gray-100">
        <% @harvests.each do |harvest| %>
          <%= render "row", harvest: harvest %>
        <% end %>
      </tbody>
    </table>
    <% if @harvests.empty? %>
      <div class="px-6 py-12 text-center text-gray-400 text-sm">No harvests yet. Select a plant to add one.</div>
    <% end %>
  </div>

  <div class="w-80 shrink-0 border-l border-gray-200 bg-white overflow-y-auto">
    <%= turbo_frame_tag "inspect" do %>
      <div class="p-6 text-center text-gray-400 text-sm mt-16">Select a record to view details</div>
    <% end %>
  </div>
</div>
