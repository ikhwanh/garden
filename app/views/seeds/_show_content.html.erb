<div class="p-4 space-y-4">
  <div class="flex items-start justify-between gap-2">
    <h2 class="text-base font-semibold text-gray-900"><%= seed.name %></h2>
    <div class="flex items-center gap-3 shrink-0">
      <%= link_to "Edit", edit_seed_path(seed),
          data: { turbo_frame: "inspect" },
          class: "text-xs text-gray-500 hover:text-gray-900" %>
      <%= button_to "Delete", seed_path(seed), method: :delete,
          data: { turbo_confirm: "Delete \"#{seed.name}\"?" },
          class: "text-xs text-red-500 hover:text-red-700 bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>

  <dl class="space-y-3">
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Germination</dt>
      <dd class="mt-0.5 text-sm text-gray-900"><%= seed.germination_days ? "#{seed.germination_days} days" : "—" %></dd>
    </div>
    <div>
      <dt class="text-xs font-medium text-gray-400 uppercase tracking-wide">Transplanted</dt>
      <dd class="mt-0.5 text-sm text-gray-900"><%= seed.transplanted_at ? seed.transplanted_at.strftime("%b %d, %Y") : "—" %></dd>
    </div>
  </dl>

  <% if seed.plants.any? %>
    <div class="pt-3 border-t border-gray-100">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-2">Plants using this seed</p>
      <ul class="space-y-1">
        <% seed.plants.each do |plant| %>
          <li>
            <%= link_to plant.name, plant_path(plant),
                data: { turbo_frame: "inspect" },
                class: "text-sm text-blue-600 hover:text-blue-800" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
