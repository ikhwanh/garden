<tr id="seed_<%= seed.id %>" class="hover:bg-gray-50">
  <td class="px-4 py-2.5 text-sm font-medium text-gray-900">
    <%= link_to seed.name, seed_path(seed),
        data: { turbo_frame: "inspect" },
        class: "hover:text-blue-600" %>
  </td>
  <td class="px-4 py-2.5 text-sm text-gray-500"><%= seed.germination_days ? "#{seed.germination_days}d" : "—" %></td>
  <td class="px-4 py-2.5 text-sm text-gray-500"><%= seed.started_on ? seed.started_on.strftime("%b %d, %Y") : "—" %></td>
  <td class="px-4 py-2.5 text-sm text-gray-500"><%= seed.expected_germination_on ? seed.expected_germination_on.strftime("%b %d, %Y") : "—" %></td>
  <td class="px-4 py-2.5 text-sm text-gray-500"><%= seed.transplanted_on ? seed.transplanted_on.strftime("%b %d, %Y") : "—" %></td>
  <td class="px-4 py-2.5 text-sm text-gray-500">
    <% if seed.quantity_initial.present? %>
      <%= seed.quantity_initial %>
      <% if seed.quantity_final.present? %>
        → <%= seed.quantity_final %>
      <% end %>
    <% else %>
      —
    <% end %>
  </td>
</tr>
