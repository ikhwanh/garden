{
  "version": "1.0",
  "description": "Nursery presets for crops requiring a nursery phase before field transplanting. DAP is relative to nursery start date (started_on).",
  "nurseries": [
    {
      "id": "shallot_tss",
      "name": "Shallot (True Seed / TSS)",
      "local_name": "Bawang merah (Biji TSS)",
      "days_in_nursery": {
        "min": 30,
        "max": 45
      },
      "growing_conditions": {
        "temperature_c": {
          "min": 18,
          "max": 28,
          "optimal_min": 20,
          "optimal_max": 25
        },
        "humidity_pct": {
          "min": 60,
          "max": 85
        },
        "light_hours_per_day": {
          "min": 6,
          "max": 8
        },
        "altitude_masl": {
          "min": 0,
          "max": 600
        },
        "notes": "Use shade house (50–70% shade net) to prevent seedling scorch; consistent moisture in cocopeat media critical; target dappled/filtered sunlight throughout nursery phase"
      },
      "presets": {
        "crop_protection": [
          {
            "phase": "nursery",
            "dap_range": {
              "min": 0,
              "max": 45
            },
            "actions": [
              "Sow seeds in sterilized cocopeat or growing media in shade house",
              "Drench nursery tray with fungicide (mancozeb / Previcur) at 10 DAP to prevent damping-off",
              "Protect seedlings from heavy rain and strong wind for entire nursery phase"
            ]
          }
        ],
        "pest_disease_checklist": [
          {
            "phase": "nursery",
            "dap_range": {
              "min": 0,
              "max": 45
            },
            "pests": [
              {
                "name": "Damping-off (Pythium / Rhizoctonia)",
                "inspect_part": "stem base at soil level",
                "action_threshold": "seedling collapse found",
                "inspection_interval_days": 2
              },
              {
                "name": "Thrips (Thrips tabaci)",
                "inspect_part": "shoot tips & leaf underside",
                "action_threshold": ">5 insects per clump",
                "inspection_interval_days": 3
              },
              {
                "name": "Leaf blight (Alternaria porri)",
                "inspect_part": "leaves",
                "action_threshold": ">5% of plants affected",
                "inspection_interval_days": 5
              }
            ]
          }
        ],
        "growth_benchmarks": [
          {
            "dap": 30,
            "targets": {
              "plant_height_cm": {
                "min": 8,
                "max": 15
              },
              "leaf_count": {
                "min": 3,
                "max": 5
              }
            },
            "notes": "Mid-nursery check; seedlings should be vigorous and upright"
          },
          {
            "dap": 40,
            "targets": {
              "plant_height_cm": {
                "min": 12,
                "max": 20
              },
              "leaf_count": {
                "min": 4,
                "max": 6
              }
            },
            "notes": "End of nursery phase; seedlings ready to transplant to field"
          }
        ],
        "fertilization_schedule": [
          {
            "phase": "nursery",
            "dap_range": {
              "min": 0,
              "max": 45
            },
            "interval_days": 7,
            "fertilizers": [
              "Liquid organic fertilizer (diluted)",
              "NPK foliar spray (low dose)"
            ],
            "notes": "Light feeding in nursery tray; avoid salt burn on young seedlings"
          }
        ]
      }
    },
